<!DOCTYPE html>
<html lang="sk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Konfigurátor — ERIOS</title>
<meta name="description" content="Zistite za pár minút orientačnú investíciu a návratnosť ERIOS pre vašu firmu. Nezáväzné.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
:root{
  --crimson:#C8003C;--magenta:#98154B;--plum:#6C2448;--teal:#0C5448;--teal-ink:#0B201D;
  --paper:#FAF8F3;--ink:#0E211C;--ink2:#3C5048;--ink3:#647A71;--teal-light:#7FD9C9;
  --accent:#C8003C;
  --grad:linear-gradient(100deg,var(--crimson) 0%,var(--magenta) 32%,var(--plum) 55%,var(--teal) 100%);
  --maxw:1180px;--pad:clamp(20px,5vw,40px);--sect:clamp(84px,11vw,148px);--r:18px;
  --shadow:0 18px 50px -24px rgba(11,32,29,.45);
  --font-d:'Manrope',system-ui,sans-serif;--font-b:'Source Sans 3',system-ui,sans-serif;--font-m:'JetBrains Mono',ui-monospace,monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%;background:#F4F2EC}
body{font-family:var(--font-b);background:transparent;color:var(--ink);line-height:1.6;font-size:clamp(16px,1.05vw,17px);overflow-x:hidden;min-height:100vh}
body::before{content:"";position:fixed;inset:0;z-index:-2;pointer-events:none;background:radial-gradient(58vw 58vw at 86% -6%,rgba(200,0,60,.055),transparent 60%),radial-gradient(54vw 54vw at -12% 112%,rgba(12,84,72,.07),transparent 60%),radial-gradient(rgba(12,84,72,.05) 1px,transparent 1.5px) 0 0/30px 30px,linear-gradient(180deg,#FAF8F3,#F1EFE8)}
.bg-orbs{position:fixed;inset:0;z-index:-1;overflow:hidden;pointer-events:none}
.bg-orbs span{position:absolute;border-radius:50%;filter:blur(70px);opacity:.55;will-change:transform}
.orb1{width:48vw;height:48vw;left:-12vw;top:-14vw;background:radial-gradient(circle,rgba(200,0,60,.16),transparent 70%);animation:orbA 26s ease-in-out infinite}
.orb2{width:54vw;height:54vw;right:-16vw;bottom:-18vw;background:radial-gradient(circle,rgba(12,84,72,.18),transparent 70%);animation:orbB 32s ease-in-out infinite}
.orb3{width:34vw;height:34vw;right:16vw;top:6vw;background:radial-gradient(circle,rgba(127,217,201,.16),transparent 70%);animation:orbA 30s ease-in-out infinite reverse}
@keyframes orbA{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(4vw,3vw) scale(1.08)}}
@keyframes orbB{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(-5vw,-3vw) scale(1.1)}}

/* Výsledok – karty + graf */
.roi-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1rem;margin:1.6rem 0 1.2rem}
.rc{background:rgba(12,84,72,.05);border:1px solid rgba(12,84,72,.16);border-radius:16px;padding:1rem 1.1rem}
.rc .k{font-family:var(--font-m);font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;color:var(--teal);display:block;margin-bottom:.5rem}
.rc .v{font-family:var(--font-d);font-weight:800;font-size:clamp(1.25rem,3vw,1.6rem);color:var(--ink);display:block}
.rc .sub{font-size:.76rem;color:var(--ink3);margin-top:.25rem;display:block}
.chart-legend{display:flex;flex-wrap:wrap;gap:1.1rem;font-family:var(--font-m);font-size:.72rem;color:var(--ink2);margin:.4rem 0 .6rem}
.chart-legend span{display:inline-flex;align-items:center;gap:.45em}
.chart-legend .ln{width:16px;height:3px;background:var(--teal);display:inline-block;border-radius:2px}
.chart-legend .ln.dash{height:0;background:none;border-top:2px dashed #888780}
.chart-legend .dot{width:10px;height:10px;border-radius:50%;background:var(--crimson);display:inline-block}
.chart-box{position:relative;width:100%;height:300px;margin-bottom:.4rem}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
h1,h2,h3,h4{font-family:var(--font-d);line-height:1.08;letter-spacing:-.02em;font-weight:800}
.container{width:100%;max-width:var(--maxw);margin-inline:auto;padding-inline:var(--pad)}
.eyebrow{font-family:var(--font-m);font-size:.72rem;font-weight:500;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);display:inline-flex;align-items:center;gap:.6em;margin-bottom:1.1rem}
.eyebrow::before{content:"";width:26px;height:1px;background:var(--accent)}
.grad-text{background:var(--grad);-webkit-background-clip:text;background-clip:text;color:transparent}

/* Tlačidlá (z indexu) */
.btn{display:inline-flex;align-items:center;gap:.55em;font-family:var(--font-d);font-weight:700;font-size:.98rem;padding:.85em 1.5em;border-radius:999px;border:1.5px solid transparent;cursor:pointer;transition:transform .18s ease,box-shadow .25s ease,background .25s,color .25s;white-space:nowrap}
.btn-primary{background:var(--grad);color:#fff;box-shadow:0 14px 30px -12px rgba(200,0,60,.55);background-size:160% 100%}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 20px 40px -12px rgba(200,0,60,.6);background-position:100% 0}
.btn-primary[disabled]{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none}
.btn-ghost{border-color:rgba(14,33,28,.25);color:var(--ink);background:transparent}
.btn-ghost:hover{background:var(--ink);color:var(--paper);transform:translateY(-2px)}
.btn .arr{transition:transform .2s}.btn:hover .arr{transform:translateX(3px)}

/* Hlavička (z indexu) */
.header{position:sticky;top:0;z-index:60;background:rgba(255,255,255,.9);backdrop-filter:blur(16px) saturate(1.3);-webkit-backdrop-filter:blur(16px) saturate(1.3);border-bottom:1px solid rgba(11,32,29,.08)}
.nav{display:flex;align-items:center;justify-content:space-between;gap:1rem;height:68px}
.brand{display:inline-flex;align-items:center;padding:0;transition:transform .2s ease,opacity .2s ease}
.brand:hover{transform:translateY(-1px);opacity:.85}
.nav-right{display:flex;align-items:center;gap:clamp(.8rem,2vw,1.4rem)}
.nav-back{font-family:var(--font-d);font-weight:600;font-size:.92rem;color:var(--ink);opacity:.78;transition:opacity .2s,color .2s}
.nav-back:hover{opacity:1;color:var(--accent)}

/* Logo s točiacim O (z indexu) */
.brand-live{display:inline-flex;align-items:center;height:33px;line-height:0}
.brand-live img{height:100%;width:auto;display:block}
.brand-live .s{margin-left:9px}
.brand-live .o-spin{height:100%;aspect-ratio:1;display:block;margin-left:11px}
.o-spin circle{fill:var(--teal-light)}
.o-spin .ring{transform-origin:50px 50px}
.o-spin .rA{animation:eriosOspin 42s linear infinite}
.o-spin .rB{animation:eriosOspin 30s linear infinite reverse}
.o-spin .rC{animation:eriosOspin 22s linear infinite}
@keyframes eriosOspin{to{transform:rotate(360deg)}}
.header .o-spin circle{fill:#0c6b5c}
.header .brand-live .s{filter:brightness(.5) saturate(1.4)}

/* Intro */
.intro{padding:clamp(34px,6vw,64px) 0 clamp(8px,2vw,18px)}
.intro h1{font-size:clamp(2rem,5vw,3.2rem);margin:0 0 1rem;max-width:16ch}
.intro .lead{font-size:clamp(1.05rem,1.6vw,1.22rem);color:var(--ink2);max-width:52ch}
.intro-meta{display:flex;flex-wrap:wrap;gap:.6rem;margin-top:1.5rem}
.pill{font-family:var(--font-m);font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--teal);background:rgba(12,84,72,.08);border:1px solid rgba(12,84,72,.18);border-radius:999px;padding:.5em 1em;display:inline-flex;align-items:center;gap:.5em}

/* Karta konfigurátora */
.cfg-wrap{padding:clamp(8px,2vw,18px) 0 clamp(70px,10vw,120px)}
.cfg-card{max-width:780px;margin-inline:auto;background:rgba(255,255,255,.78);backdrop-filter:blur(10px);border:1px solid rgba(11,32,29,.1);border-radius:24px;box-shadow:var(--shadow);padding:clamp(22px,4vw,40px);position:relative;overflow:hidden}
.cfg-card::before{content:"";position:absolute;inset:0 0 auto 0;height:4px;background:var(--grad)}

/* Progres */
.cfg-progress{margin-bottom:clamp(22px,4vw,34px)}
.cfg-steps{display:flex;justify-content:space-between;gap:.4rem;margin-bottom:.8rem}
.cfg-steps .st{flex:1;font-family:var(--font-m);font-size:.62rem;letter-spacing:.08em;text-transform:uppercase;color:var(--ink3);text-align:center;opacity:.55;transition:.25s;line-height:1.3}
.cfg-steps .st.active{opacity:1;color:var(--teal)}
.cfg-steps .st.done{opacity:1;color:var(--crimson)}
.cfg-track{height:6px;border-radius:999px;background:rgba(11,32,29,.08);overflow:hidden}
.cfg-fill{height:100%;width:20%;background:var(--grad);border-radius:999px;transition:width .4s cubic-bezier(.22,.61,.36,1)}

/* Krok */
.stephead{margin-bottom:1.4rem}
.stephead .kc{font-family:var(--font-m);font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--crimson);display:block;margin-bottom:.4rem}
.stephead h2{font-size:clamp(1.4rem,3vw,1.95rem)}
.steptip{color:var(--ink2);font-size:.96rem;margin-top:.5rem;max-width:54ch}
#stepBody{animation:stepIn .4s cubic-bezier(.22,.61,.36,1)}
@keyframes stepIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}

.qgroup{margin-bottom:1.5rem}
.qgroup:last-child{margin-bottom:0}
.qlabel{font-family:var(--font-m);font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--teal);display:block;margin-bottom:.7rem}
.qlabel .opt{color:var(--ink3);text-transform:none;letter-spacing:0;font-size:.78rem;margin-left:.4em}
.note{background:rgba(12,84,72,.06);border:1px solid rgba(12,84,72,.16);border-radius:14px;padding:.9rem 1.1rem;color:var(--ink2);font-size:.92rem;line-height:1.55}

/* Chips */
.chips{display:flex;flex-wrap:wrap;gap:.6rem}
.chip{font-family:var(--font-d);font-weight:600;font-size:.92rem;color:var(--ink);background:#fff;border:1.5px solid rgba(11,32,29,.14);border-radius:999px;padding:.6em 1.1em;cursor:pointer;transition:transform .12s,border-color .2s,background .2s,color .2s,box-shadow .2s;line-height:1.2}
.chip:hover{border-color:var(--teal);transform:translateY(-1px)}
.chip.sel{background:var(--teal-ink);color:#fff;border-color:var(--teal-ink);box-shadow:0 10px 24px -14px rgba(11,32,29,.6)}
.chip.sel::after{content:"✓";margin-left:.5em;color:var(--teal-light);font-weight:700}
.chips.multi .chip.sel::after{content:"✓"}

/* Polia */
.field{display:flex;flex-direction:column;gap:.4rem;margin-bottom:1rem}
.field:last-child{margin-bottom:0}
.field label{font-family:var(--font-m);font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--teal)}
.field label .opt{color:var(--ink3);text-transform:none;letter-spacing:0;font-size:.78rem;margin-left:.4em}
.field input,.field select,.field textarea{font-family:var(--font-b);font-size:1rem;color:var(--ink);background:#fff;border:1.5px solid rgba(11,32,29,.16);border-radius:12px;padding:.74em .9em;transition:border-color .2s,box-shadow .2s;width:100%}
.field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:var(--crimson);box-shadow:0 0 0 4px rgba(200,0,60,.1)}
.field textarea{resize:vertical;min-height:84px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
@media(max-width:560px){.grid2{grid-template-columns:1fr}}

/* Slider */
.slider{margin-bottom:1.1rem}
.slider .sl-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:.4rem}
.slider .sl-lab{font-family:var(--font-m);font-size:.74rem;letter-spacing:.06em;color:var(--ink2)}
.slider .sl-val{font-family:var(--font-d);font-weight:800;color:var(--crimson);font-size:1.05rem}
.slider input[type=range]{-webkit-appearance:none;appearance:none;width:100%;height:6px;border-radius:999px;background:rgba(11,32,29,.12);outline:none}
.slider input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;background:var(--crimson);cursor:pointer;box-shadow:0 4px 10px -2px rgba(200,0,60,.5)}
.slider input[type=range]::-moz-range-thumb{width:20px;height:20px;border:0;border-radius:50%;background:var(--crimson);cursor:pointer}

.qhint{font-size:.84rem;color:var(--ink3);margin:-.3rem 0 .7rem}

/* Meradlo presnosti */
.acc{margin-top:1.2rem}
.acc-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:.45rem}
.acc-top span:first-child{font-family:var(--font-m);font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--teal)}
.acc-val{font-family:var(--font-d);font-weight:800;color:var(--crimson)}
.acc-track{height:8px;border-radius:999px;background:rgba(11,32,29,.1);overflow:hidden}
.acc-fill{height:100%;border-radius:999px;background:var(--grad);transition:width .5s cubic-bezier(.22,.61,.36,1)}
.acc-tip{font-size:.84rem;color:var(--ink2);margin-top:.6rem;line-height:1.5}
.acc-res{background:rgba(12,84,72,.05);border:1px solid rgba(12,84,72,.16);border-radius:16px;padding:1.1rem 1.2rem}

/* Súhlas */
.consent{display:flex;gap:.7rem;align-items:flex-start;background:rgba(12,84,72,.05);border:1px solid rgba(12,84,72,.16);border-radius:14px;padding:.9rem 1rem;font-size:.9rem;color:var(--ink2);line-height:1.5}
.consent input{margin-top:.25rem;width:18px;height:18px;accent-color:var(--crimson);flex:0 0 auto}
.consent a{color:var(--crimson);text-decoration:underline}
.hp{position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden}

/* Navigácia kroku */
.cfg-nav{display:flex;justify-content:space-between;gap:1rem;margin-top:clamp(22px,4vw,34px);padding-top:1.4rem;border-top:1px solid rgba(11,32,29,.08)}
.cfg-nav .btn{flex:0 0 auto}
#backBtn[hidden]{visibility:hidden}
.req-hint{font-size:.82rem;color:var(--crimson);margin-top:.6rem;min-height:1.1em;font-family:var(--font-m);letter-spacing:.02em}

/* Výsledok */
.result{display:none;max-width:780px;margin-inline:auto;background:rgba(255,255,255,.82);backdrop-filter:blur(10px);border:1px solid rgba(11,32,29,.1);border-radius:24px;box-shadow:var(--shadow);padding:clamp(24px,4vw,44px);position:relative;overflow:hidden;animation:stepIn .5s cubic-bezier(.22,.61,.36,1)}
.result::before{content:"";position:absolute;inset:0 0 auto 0;height:4px;background:var(--grad)}
.result.show{display:block}
.res-eyebrow{font-family:var(--font-m);font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--teal)}
.price-line{margin:.4rem 0 .2rem;font-family:var(--font-d);font-weight:800;line-height:1.05}
.price-line .tier{display:block;font-size:1rem;color:var(--ink2);font-weight:600;font-family:var(--font-m);letter-spacing:.1em;text-transform:uppercase;margin-bottom:.4rem}
.price-big{font-size:clamp(2.4rem,7vw,4rem);background:var(--grad);-webkit-background-clip:text;background-clip:text;color:transparent}
.price-from{font-size:clamp(1.1rem,2.5vw,1.4rem);color:var(--ink2);font-weight:700}
.roi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;margin:1.6rem 0}
.roi-card{background:rgba(12,84,72,.05);border:1px solid rgba(12,84,72,.16);border-radius:16px;padding:1.1rem 1.2rem}
.roi-card .k{font-family:var(--font-m);font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--teal);display:block;margin-bottom:.5rem}
.roi-card .v{font-family:var(--font-d);font-weight:800;font-size:clamp(1.3rem,3vw,1.7rem);color:var(--ink)}
.roi-card .sub{font-size:.78rem;color:var(--ink3);margin-top:.3rem}
.disclaimer{background:rgba(200,0,60,.05);border:1px solid rgba(200,0,60,.18);border-radius:14px;padding:1rem 1.15rem;font-size:.88rem;color:var(--ink2);line-height:1.55;margin:1.4rem 0}
.next-steps{display:flex;align-items:center;gap:.8rem;flex-wrap:wrap;margin-top:1.4rem}
.recap{margin-top:1.8rem;border-top:1px solid rgba(11,32,29,.08);padding-top:1.2rem}
.recap h3{font-family:var(--font-m);font-size:.74rem;letter-spacing:.14em;text-transform:uppercase;color:var(--ink3);font-weight:500;margin-bottom:.8rem}
.recap dl{display:grid;grid-template-columns:auto 1fr;gap:.4rem 1.2rem;font-size:.9rem}
.recap dt{color:var(--ink3);font-family:var(--font-m);font-size:.8rem}
.recap dd{color:var(--ink);font-weight:600}
.spinner{width:18px;height:18px;border:2px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;display:inline-block;animation:sp .7s linear infinite;vertical-align:-3px}
@keyframes sp{to{transform:rotate(360deg)}}

/* Pätička */
.footer{background:var(--teal-ink);color:#cfe0db;margin-top:auto}
.footer .container{padding-block:clamp(36px,6vw,56px);display:flex;flex-wrap:wrap;gap:1.4rem;align-items:center;justify-content:space-between}
.footer-brand .brand-live{height:30px}
.footer-brand .brand-live img{height:100%}
.footer-brand .o-spin circle{fill:var(--teal-light)}
.footer-brand .brand-live .o-spin{filter:drop-shadow(0 0 9px rgba(127,217,201,.4))}
.footer small{display:block;color:#7f9a92;font-size:.82rem;margin-top:.6rem}
.footer a.flink{color:#cfe0db;font-family:var(--font-d);font-weight:600;font-size:.92rem;opacity:.85}
.footer a.flink:hover{opacity:1;color:var(--teal-light)}

@media (prefers-reduced-motion:reduce){
  .o-spin .ring{animation:none!important}
  #stepBody,.result{animation:none!important}
  .bg-orbs span{animation:none!important}
}
</style>
</head>
