        { key:"odvetvie", type:"single", label:"Odvetvie", opt:true,
          options:[["Strojárstvo","strojarstvo"],["Potravinárstvo","potravinarstvo"],["Výroba na zákazku","zakazka"],["Retail / e-commerce","retail"],["Logistika","logistika"],["Iné","ine"]] },
        { key:"odvetvieIne", type:"text", label:"Aké odvetvie?", opt:true, placeholder:"doplňte", showIf:{key:"odvetvie",val:"ine"} }
      ]
    },
    {
      label:"Ciele", title:"Čo chcete riešiť",
      tip:"Vyberte všetko, čo sedí — podľa toho nastavíme dôraz.",
      qs:[
        { key:"ciele", type:"multi", def:true, label:"Hlavné ciele", hint:"Predvolene zaškrtnuté všetky — odznačte, čo vás netrápi.",
          options:[["Sklad a cashflow","sklad"],["Plánovanie výroby","planovanie"],["Riadenie ľudí a výkonu","ludia"],["Vizualizácia a reporting","vizualizacia"],["Expedícia / logistika","expedicia"],["Kvalita a chybovosť","kvalita"]] },
        { key:"integracie", type:"multi", label:"Potrebné integrácie", opt:true,
          options:[["Účtovníctvo","uctovnictvo"],["E-shop","eshop"],["Doprava / kuriéri","doprava"],["Váhy / stroje","stroje"],["Žiadne / neviem","ziadne"]] }
      ]
    },
    {
      label:"Kontakt", title:"Kam pošleme výsledok",
      tip:"Po odoslaní vám hneď zobrazíme orientačnú cenu aj návratnosť.",
      qs:[
        { key:"meno", type:"text", req:true, label:"Meno a priezvisko", placeholder:"Ján Novák" },
        { key:"firma", type:"text", req:true, label:"Firma", placeholder:"Názov firmy" },
        { key:"email", type:"email", req:true, label:"Firemný e-mail", placeholder:"jan@firma.sk" },
        { key:"telefon", type:"tel", label:"Telefón", opt:true, placeholder:"+421…" },
        { key:"rola", type:"single", label:"Vaša rola", opt:true,
          options:[["Majiteľ","majitel"],["Manažér prevádzky","manazer"],["IT","it"],["Iné","ine"]] },
        { key:"poznamka", type:"textarea", label:"Poznámka", opt:true, placeholder:"Čokoľvek, čo by sme mali vedieť…" },
        { key:"consent", type:"consent", req:true,
          text:'Súhlasím so spracovaním údajov za účelom prípravy ponuky a kontaktovania. <a href="index.html#kontakt">Zásady spracovania</a>.' }
      ]
    }
  ];

  /* ====================== STAV ====================== */
  var state = {};
  var step = 0;

  var $ = function(s){ return document.querySelector(s); };
  var body = $("#stepBody"), labels = $("#stepLabels"), fill = $("#cfgFill"),
      counter = $("#stepCounter"), title = $("#stepTitle"), tip = $("#stepTip"),
      backBtn = $("#backBtn"), nextBtn = $("#nextBtn"), reqHint = $("#reqHint");

  document.getElementById("yr").textContent = new Date().getFullYear();
  body.addEventListener("input", updateMeter);

  function updateMeter(){
    var f=document.getElementById("accFill"), v=document.getElementById("accVal");
    if(!f) return;
    if(filledInputs()===0){ f.style.width="8%"; if(v) v.textContent="—"; return; }
    var a=computeAccuracy();
    f.style.width=a+"%"; if(v) v.textContent=a+" %";
  }

  // labely krokov
  STEPS.forEach(function(s,i){
    var el = document.createElement("div");
    el.className = "st"; el.textContent = (i+1)+". "+s.label; el.dataset.i = i;
    labels.appendChild(el);
  });

  function visible(q){
    if(!q.showIf) return true;
    return state[q.showIf.key] === q.showIf.val;
  }

  function render(){
    var s = STEPS[step];
    counter.textContent = "Krok "+(step+1)+" / "+STEPS.length;
    title.textContent = s.title;
    tip.textContent = s.tip;
    fill.style.width = ((step+1)/STEPS.length*100)+"%";
    Array.prototype.forEach.call(labels.children,function(el,i){
      el.classList.toggle("active", i===step);
      el.classList.toggle("done", i<step);
    });
    backBtn.hidden = step===0;
    nextBtn.innerHTML = step===STEPS.length-1
      ? 'Zobraziť orientačnú cenu <span class="arr">→</span>'
      : 'Pokračovať <span class="arr">→</span>';

    body.innerHTML = "";
    s.qs.forEach(function(q){
      if(!visible(q)) return;
      body.appendChild(buildQ(q));
    });
    reqHint.textContent = "";
    syncNext();
    updateMeter();
  }

  function buildQ(q){
    var wrap = document.createElement("div");
    if(q.type==="note"){
      wrap.className="note"; wrap.textContent=q.text; return wrap;
    }
    if(q.type==="single" || q.type==="multi"){
      wrap.className="qgroup";
      wrap.innerHTML = '<span class="qlabel">'+q.label+(q.opt?' <span class="opt">(nepovinné)</span>':'')+'</span>'+(q.hint?'<p class="qhint">'+q.hint+'</p>':'');
      var c = document.createElement("div");
      c.className = "chips"+(q.type==="multi"?" multi":"");
      q.options.forEach(function(o){
        var b = document.createElement("button");
        b.type="button"; b.className="chip"; b.textContent=o[0]; b.dataset.val=o[1];
        var sel = q.type==="multi"
          ? (Array.isArray(state[q.key]) && state[q.key].indexOf(o[1])>-1)
          : state[q.key]===o[1];
        if(sel) b.classList.add("sel");
        b.addEventListener("click",function(){
          if(q.type==="multi"){
            var arr = Array.isArray(state[q.key])?state[q.key].slice():[];
            var ix = arr.indexOf(o[1]);
            if(ix>-1){ arr.splice(ix,1); b.classList.remove("sel"); }
            else { arr.push(o[1]); b.classList.add("sel"); }
            state[q.key]=arr;
          } else {
            state[q.key]=o[1];
            Array.prototype.forEach.call(c.children,function(x){x.classList.remove("sel");});
            b.classList.add("sel");
            if(q.showIfTrigger) render(); // prekresli ak ovláda podmienené pole
          }
          syncNext();
        });
        c.appendChild(b);
      });
      // ak na túto otázku visí podmienené pole, po zmene prekresli
      if(STEPS[step].qs.some(function(x){return x.showIf && x.showIf.key===q.key;})) q.showIfTrigger=true;
      wrap.appendChild(c);
      return wrap;
    }
    if(q.type==="slider"){
      wrap.className="slider";
      var val = state[q.key]!=null ? state[q.key] : q.def;
      state[q.key]=val;
      wrap.innerHTML =
        '<div class="sl-top"><span class="sl-lab">'+q.label+'</span><span class="sl-val">'+val+' %</span></div>'+
        '<input type="range" min="'+q.min+'" max="'+q.max+'" value="'+val+'">';
      var rng = wrap.querySelector("input"), out = wrap.querySelector(".sl-val");
      rng.addEventListener("input",function(){ state[q.key]=+rng.value; out.textContent=rng.value+" %"; });
      return wrap;
    }
    if(q.type==="meter"){
      wrap.className="acc";
      wrap.innerHTML =
        '<div class="acc-top"><span>Presnosť orientačného odhadu</span><span class="acc-val" id="accVal">—</span></div>'+
        '<div class="acc-track"><div class="acc-fill" id="accFill" style="width:8%"></div></div>'+
        '<p class="acc-tip">Doplňte čísla a odhad sa spresní. Posledný krok k presnému číslu — a často k ešte väčšiemu potenciálu — doladí náš špecialista.</p>';
      return wrap;
    }
    if(q.type==="consent"){
      wrap.className="consent";
      wrap.innerHTML = '<input type="checkbox" id="consentChk"><label for="consentChk">'+q.text+'</label>';
      var chk = wrap.querySelector("input");
      chk.checked = !!state[q.key];
      chk.addEventListener("change",function(){ state[q.key]=chk.checked; syncNext(); });
      return wrap;
    }
    // text / email / tel / number / textarea
    wrap.className="field";
    var id="f_"+q.key;
    var inputHtml = q.type==="textarea"
      ? '<textarea id="'+id+'" placeholder="'+(q.placeholder||'')+'"></textarea>'
      : '<input id="'+id+'" type="'+(q.type==="number"?"number":(q.type==="email"?"email":(q.type==="tel"?"tel":"text")))+'" placeholder="'+(q.placeholder||'')+'" '+(q.type==="number"?'min="0" inputmode="numeric"':'')+'>';
    wrap.innerHTML = '<label for="'+id+'">'+q.label+(q.opt?' <span class="opt">(nepovinné)</span>':'')+'</label>'+inputHtml;
    var inp = wrap.querySelector("input,textarea");
    if(state[q.key]!=null) inp.value = state[q.key];
    inp.addEventListener("input",function(){
      state[q.key] = q.type==="number" ? (inp.value===""?null:+inp.value) : inp.value;
      syncNext();
    });
    return wrap;
  }

  function stepValid(){
    var s = STEPS[step], ok=true;
    s.qs.forEach(function(q){
      if(!q.req || !visible(q)) return;
      var v = state[q.key];
      if(q.type==="consent"){ if(!v) ok=false; }
      else if(q.type==="multi"){ if(!Array.isArray(v)||!v.length) ok=false; }
      else if(q.type==="email"){ if(!v || !/^\S+@\S+\.\S+$/.test(v)) ok=false; }
      else { if(v==null || v==="") ok=false; }
    });
    return ok;
  }

  function syncNext(){
    var ok = stepValid();
    nextBtn.disabled = !ok;
    if(ok) reqHint.textContent="";
  }

  nextBtn.addEventListener("click",function(){
    if(!stepValid()){
      reqHint.textContent = "Vyplňte prosím povinné polia.";
      return;
    }
    if(step < STEPS.length-1){ step++; render(); window.scrollTo({top:0,behavior:"smooth"}); }
    else { submit(); }
  });
  backBtn.addEventListener("click",function(){
    if(step>0){ step--; render(); window.scrollTo({top:0,behavior:"smooth"}); }
  });

  /* ====================== VÝPOČTY ====================== */
  function computeTierIndex(){
    var o = SCORE_OBRAT[state.obrat]||0, z = SCORE_ZAM[state.zamestnanci]||0;
    var score = (o+z)/2;                       // 0..4
    if(state.prevadzky==="4+") score += 0.5;
    if(state.pouzivatelia==="80+") score += 0.4;
    else if(state.pouzivatelia==="30-80") score += 0.2;
    if(state.procesy==="viac" || (state.erp==="ano" && state.mes==="ano")) score += 0.4;
    if(Array.isArray(state.integracie)){
      var n = state.integracie.filter(function(x){return x!=="ziadne";}).length;
      score += Math.min(0.4, n*0.1);
    }
    var idx = Math.round(score * (3/4));        // 0..~ -> 0..3
    return Math.max(0, Math.min(3, idx));
  }

  function num(k){ var v=state[k]; return (typeof v==="number" && !isNaN(v))?v:0; }
  function filledInputs(){ return 0; }
  function computeAccuracy(){ return 0; }

  function rate(m){
    if(m<=3) return 0.30;                 // počiatočné nasadenie
    if(m<=DEPLOY) return 0.60 + (m-3)*0.12; // nábeh
    return 1 + (m-DEPLOY)*0.004;           // jemné zrýchľovanie (viac procesov = viac úspory)
  }

  function computeROI(price){
    var emp = EMP_MID[state.zamestnanci] || 6;
    var payroll = emp * AVG_WAGE_M * 12 * LOAD;
    var obratMid = OBRAT_MID[state.obrat] || 0;
    var annual    = payroll * SAVE_PCT;
    var annualOpt = payroll * SAVE_PCT_OPT;
    if(obratMid){ annual = Math.min(annual, obratMid*OBRAT_CAP); annualOpt = Math.min(annualOpt, obratMid*OBRAT_CAP_OPT); }
    if(annual < price*0.3) annual = price*0.3;   // poistka, nech návratnosť nie je absurdná
    if(annualOpt < annual) annualOpt = annual;
    var monthsCons = Math.max(5, Math.round(price/(annual/12)));
    var monthsOpt  = Math.max(4, Math.round(price/(annualOpt/12)));
    if(monthsOpt > monthsCons) monthsOpt = monthsCons;
    var b = annual/12, cum=0, labels=[0], sav=[0];
    for(var m=1;m<=48;m++){ cum += b*rate(m); labels.push(m); sav.push(Math.round(cum)); }
    var be=null; for(var i=1;i<=48;i++){ if(sav[i]>=price){ be=i; break; } }
    var net48 = Math.round(sav[48]-price);
    return { annual:Math.round(annual), annualOpt:Math.round(annualOpt),
             monthsCons:monthsCons, monthsOpt:monthsOpt,
             labels:labels, sav:sav, be:be, net48:net48 };
  }

  function fmtEur(n){ return Math.round(n).toLocaleString("sk-SK") + " €"; }
  function fmtMonths(m){
    if(m==null) return null;
    if(m<=24) return "~"+m+" mes.";
    var y=(m/12); return "~"+(y).toFixed(1).replace(".",",")+" roka/rokov";
  }

  /* ====================== ODOSLANIE + VÝSLEDOK ====================== */
  function labelFor(key,val){
    for(var i=0;i<STEPS.length;i++){
      var q=STEPS[i].qs.filter(function(x){return x.key===key;})[0];
      if(q&&q.options){ var o=q.options.filter(function(x){return x[1]===val;})[0]; if(o)return o[0]; }
    }
    return val;
  }

  function buildPayload(tier,price,roi){
    var d = {
      _subject: "Nová žiadosť z konfigurátora ERIOS — "+(state.firma||""),
      uroven: tier.name,
      cena_od: price,
      // kontakt
      meno: state.meno||"", firma: state.firma||"", email: state.email||"",
      telefon: state.telefon||"", rola: state.rola?labelFor("rola",state.rola):"", poznamka: state.poznamka||"",
      // firma
      obrat: labelFor("obrat",state.obrat), zamestnanci: labelFor("zamestnanci",state.zamestnanci),
      prevadzky: state.prevadzky||"", pouzivatelia: state.pouzivatelia||"",
      // stav
      procesy: state.procesy?labelFor("procesy",state.procesy):"", erp: state.erp||"", erp_aky: state.erpName||"",
      mes: state.mes||"", mes_aky: state.mesName||"", odvetvie: state.odvetvie?labelFor("odvetvie",state.odvetvie):"", odvetvie_ine: state.odvetvieIne||"",
      // ciele
      ciele: Array.isArray(state.ciele)?state.ciele.map(function(v){return labelFor("ciele",v);}).join(", "):"",
      integracie: Array.isArray(state.integracie)?state.integracie.map(function(v){return labelFor("integracie",v);}).join(", "):"",
      // návratnosť (orientačná, počítaná z veľkosti firmy)
      orient_rocna_uspora: roi.annual,
      orient_navratnost_mes: roi.monthsCons,
      orient_navratnost_od_mes: roi.monthsOpt,
      orient_cisty_prinos_48m: roi.net48,
      zdroj: location.href
    };
    return d;
  }

  function submit(){
    // anti-spam: ak je honeypot vyplnený, predstieraj úspech a neodosielaj
    var hp = document.querySelector('input[name="_gotcha"]');
    var idx = computeTierIndex();
    var tier = TIERS[idx], price = tier.from;
    var roi = computeROI(price);
    if(hp && hp.value){ showResult(tier, price, roi, true); return; }
    var payload = buildPayload(tier, price, roi);

    nextBtn.disabled = true;
    nextBtn.innerHTML = 'Odosielam <span class="spinner"></span>';

    fetch(FORMSPREE, {
      method:"POST",
      headers:{ "Content-Type":"application/json", "Accept":"application/json" },
      body: JSON.stringify(payload)
    }).then(function(r){
      showResult(tier, price, roi, r && r.ok);
    }).catch(function(){
      showResult(tier, price, roi, false);
    });
  }

  function recapRow(dt,dd){ return dd ? '<dt>'+dt+'</dt><dd>'+dd+'</dd>' : ''; }

  function showResult(tier, price, roi, sent){
    $("#cfgForm").style.display="none";
    var R = $("#result"); R.classList.add("show");

    var roiHtml =
      '<div class="roi-cards">'+
        '<div class="rc"><span class="k">Vstupná investícia</span><span class="v">od '+fmtEur(price)+'</span></div>'+
        '<div class="rc"><span class="k">Orientačná návratnosť</span><span class="v">~'+roi.monthsCons+' mes.</span><span class="sub">už od ~'+roi.monthsOpt+' mes.</span></div>'+
        '<div class="rc"><span class="k">Orientačná ročná úspora</span><span class="v">od '+fmtEur(roi.annual)+'</span></div>'+
        '<div class="rc"><span class="k">Čistý prínos za 48 mes.</span><span class="v">~'+fmtEur(roi.net48)+'</span></div>'+
      '</div>'+
      '<div class="chart-legend">'+
        '<span><span class="ln"></span>Kumulatívna úspora</span>'+
        '<span><span class="ln dash"></span>Vstupná investícia</span>'+
        '<span><span class="dot"></span>Bod návratnosti</span>'+
      '</div>'+
      '<div class="chart-box"><canvas id="roiChart" role="img" aria-label="Krivka kumulatívnej úspory rastie a po približne '+roi.monthsCons+' mesiacoch prekoná vstupnú investíciu."></canvas></div>'+
      '<p style="font-size:.8rem;color:var(--ink3);margin-bottom:.4rem">Prvé mesiace = nasadenie (úspora nabieha), potom rastie naplno a zrýchľuje.</p>';

    R.innerHTML =
      '<span class="res-eyebrow">Vaša orientačná konfigurácia</span>'+
      '<div class="price-line"><span class="tier">Úroveň '+tier.name+'</span>'+
        '<span class="price-from">od </span><span class="price-big" id="priceBig">0 €</span></div>'+
      roiHtml+
      '<div class="disclaimer">Ide o <strong>orientačné, nezáväzné</strong> čísla z veľkosti vašej firmy a konzervatívnych predpokladov. '+
        'Presný — a často priaznivejší — prepočet vám pripraví '+SPECIALISTA+' z reálnych dát; návratnosť počítame na 1–5 rokov.</div>'+
      '<div class="next-steps">'+
        '<span style="font-weight:600">'+ (sent ? ('Ďakujeme! '+capit(SPECIALISTA)+' vás bude kontaktovať '+SLA+'.') : 'Výsledok je pripravený.') +'</span>'+
        '<a href="index.html" class="btn btn-primary">Späť na web <span class="arr">→</span></a>'+
      '</div>'+
      (!sent ? '<div class="disclaimer" style="background:rgba(200,0,60,.07)">Odoslanie do nášho systému zlyhalo. Napíšte nám prosím priamo cez <a href="index.html#kontakt">kontaktný formulár</a> — výsledok vyššie ostáva platný.</div>' : '')+
      '<div class="recap"><h3>Zhrnutie vašich údajov</h3><dl>'+
        recapRow("Obrat", labelFor("obrat",state.obrat))+
        recapRow("Zamestnanci", labelFor("zamestnanci",state.zamestnanci))+
        recapRow("Prevádzky", state.prevadzky||"")+
        recapRow("Odvetvie", state.odvetvie?labelFor("odvetvie",state.odvetvie):"")+
        recapRow("Súčasné riadenie", state.procesy?labelFor("procesy",state.procesy):"")+
        recapRow("Ciele", Array.isArray(state.ciele)?state.ciele.map(function(v){return labelFor("ciele",v);}).join(", "):"")+
      '</dl></div>';

    window.scrollTo({top:0,behavior:"smooth"});
    countUp($("#priceBig"), price);
    drawChart(roi, price);
  }

  function drawChart(roi, price){
    var cv = document.getElementById("roiChart");
    if(!cv || !window.Chart) return;
    var labels = roi.labels, sav = roi.sav;
    var invLine = labels.map(function(){ return price; });
    var beData  = labels.map(function(l){ return l===roi.be?price:null; });
    new Chart(cv, {
      type:"line",
      data:{ labels:labels, datasets:[
        { label:"Kumulatívna úspora", data:sav, borderColor:"#0C5448", backgroundColor:"rgba(12,84,72,.10)", borderWidth:2.5, fill:true, tension:.3, pointRadius:0 },
        { label:"Vstupná investícia", data:invLine, borderColor:"#888780", borderWidth:2, borderDash:[6,5], fill:false, pointRadius:0 },
        { label:"Bod návratnosti", data:beData, borderColor:"#C8003C", backgroundColor:"#C8003C", pointRadius:6, pointHoverRadius:7, showLine:false }
      ]},
      options:{ responsive:true, maintainAspectRatio:false,
        plugins:{ legend:{display:false}, tooltip:{ callbacks:{
          title:function(it){ return "Mesiac "+it[0].label; },
          label:function(c){ return c.raw==null?null:c.dataset.label+": "+fmtEur(c.raw); } } } },
        scales:{
          x:{ title:{display:true,text:"Mesiace",color:"#647A71",font:{size:12}}, grid:{display:false},
              ticks:{ color:"#647A71", autoSkip:false, callback:function(v,i){ return i%6===0?labels[i]:""; } } },
          y:{ beginAtZero:true, grid:{ color:"rgba(100,122,113,.15)" },
              ticks:{ color:"#647A71", callback:function(v){ return Math.round(v/1000)+"k €"; } } }
        } }
    });
  }

  function capit(s){ return s.charAt(0).toUpperCase()+s.slice(1); }

  function countUp(el, target){
    var t0=null, dur=900;
    function step(ts){
      if(!t0)t0=ts;
      var p=Math.min((ts-t0)/dur,1), e=1-Math.pow(1-p,3);
      el.textContent = fmtEur(target*e);
      if(p<1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  // predvolene zaškrtnuté ciele
  for(var si=0; si<STEPS.length; si++){
    var cq = STEPS[si].qs.filter(function(x){return x.key==="ciele";})[0];
    if(cq){ state.ciele = cq.options.map(function(o){return o[1];}); }
  }

  render();
})();
</script>
